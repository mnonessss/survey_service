# Database
POSTGRES_DB=survey_db
POSTGRES_USER=survey_user
POSTGRES_PASSWORD=change-me-strong-password
DATABASE_URL=postgresql+asyncpg://survey_user:change-me-strong-password@postgres:5432/survey_db
REDIS_URL=redis://redis:6379

# Application
APP_ENV=production
PUBLIC_APP_URL=https://your-domain.example
API_PUBLIC_URL=https://your-domain.example
CORS_ORIGINS=https://your-domain.example
DEV_AUTH_BYPASS=false

# Security (generate: openssl rand -hex 32)
CSRF_SECRET=
APP_SECRET=

# auth.vk.team OIDC (уточните у наставника VK)
VK_AUTH_ISSUER=https://auth.vk.team
VK_AUTH_REALM=
VK_AUTH_DISCOVERY_URL=
VK_AUTH_CLIENT_ID=
VK_AUTH_CLIENT_SECRET=
VK_AUTH_REDIRECT_URI=https://your-domain.example/auth/callback
VK_AUTH_FRONTEND_URL=https://your-domain.example
VK_AUTH_SCOPES=openid profile email
VK_AUTH_AUDIENCE=
VK_AUTH_JWKS_URL=

# HashiCorp Vault (секреты интеграций)
VAULT_ADDR=https://vault.example:8200
VAULT_TOKEN=
VAULT_MOUNT_POINT=secret
VAULT_EXTERNAL_KEYS_PATH=survey-platform/external-api
